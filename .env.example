FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Optional: allow only selected Feishu open_id values.
ALLOWED_USER_IDS=

# Optional: working directory for Codex operations. Defaults to ~.
CODEX_CWD=

# Optional: model override passed to Codex CLI.
CODEX_MODEL=

# Optional: enable Codex web search. Set to true or false.
CODEX_SEARCH=false

# Optional: pass --full-auto to Codex CLI. Set to true or false.
CODEX_FULL_AUTO=true

# Optional: pass --dangerously-bypass-approvals-and-sandbox to Codex CLI.
# Leave false unless you explicitly want unrestricted execution.
CODEX_DANGEROUS=false

# Optional: extra Codex CLI arguments, split with shell rules.
CODEX_EXTRA_ARGS=
